---
import type { ItemForAll } from "../feed/fetch";

import Layout from "../layouts/layout.astro";
import Section from "../layouts/section.astro";
import Title from "../components/title.astro";
import FeedItem from "../components/feed-item.astro";

import { collectAllItems } from "../feed/history";

const oneWeekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
const items = collectAllItems();
const weekly = items.reduce<ItemForAll[]>((pre, cur) => {
  if (cur.pubDate > oneWeekAgo) {
    pre.push(cur);
  }
  return pre;
}, []);
---

<Layout>
  <main>
    <Section>
      <Title>今週</Title>
      <div class="grid gap-8">
        {
          weekly.map((item) => (
            <FeedItem
              link={item.link}
              pubDate={item.pubDate}
              site={item.site}
              title={item.title}
              param={item.param}
              creator={item.creator}
              contentSnippet={item.contentSnippet}
            />
          ))
        }
      </div>
    </Section>
  </main>
</Layout>
